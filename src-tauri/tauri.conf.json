{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "Audio Device Switcher",
    "version":  "1.0.0",
    "identifier":  "com.mptechtools.audioswitcher",
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "devUrl":  "http://127.0.0.1:1420",
                  "beforeBuildCommand":  "npm run build",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "Audio Device Switcher",
                                    "width":  935,
                                    "height":  676,
                                    "minWidth":  720,
                                    "minHeight":  560,
                                    "resizable":  true,
                                    "center":  true
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "nsis"
               }
}